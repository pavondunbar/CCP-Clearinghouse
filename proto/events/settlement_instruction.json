{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SettlementInstruction",
  "description": "Emitted when a settlement instruction is created for execution",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "instruction_id",
    "settlement_type",
    "from_member_id",
    "to_member_id",
    "instrument_id"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "settlement.instruction.created" },
    "timestamp": { "type": "string", "format": "date-time" },
    "instruction_id": { "type": "string", "format": "uuid" },
    "settlement_type": {
      "type": "string",
      "enum": ["cash", "dvp", "physical"]
    },
    "netting_cycle_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "from_member_id": { "type": "string", "format": "uuid" },
    "to_member_id": { "type": "string", "format": "uuid" },
    "instrument_id": { "type": "string", "format": "uuid" },
    "quantity": { "type": "string", "pattern": "^\\d+\\.?\\d*$" },
    "amount": { "type": "string", "pattern": "^\\d+\\.?\\d*$" },
    "chain_id": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
