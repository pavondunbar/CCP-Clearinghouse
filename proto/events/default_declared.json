{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DefaultDeclared",
  "description": "Emitted when a clearing member is declared in default",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "default_event_id",
    "member_id",
    "trigger_reason",
    "total_exposure"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "default.declared" },
    "timestamp": { "type": "string", "format": "date-time" },
    "default_event_id": { "type": "string", "format": "uuid" },
    "member_id": { "type": "string", "format": "uuid" },
    "member_name": { "type": "string" },
    "trigger_reason": { "type": "string" },
    "total_exposure": { "type": "string", "pattern": "^\\d+\\.?\\d*$" },
    "breached_margin_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "margin_call_id": { "type": "string", "format": "uuid" },
          "call_amount": { "type": "string" },
          "deadline": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "additionalProperties": false
}
