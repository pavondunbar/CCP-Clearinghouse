{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "title": "Default Events",
      "type": "stat",
      "targets": [
        {
          "expr": "ccp_default_events_total",
          "legendFormat": "Total Defaults"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "id": 2,
      "title": "Waterfall Step Amounts",
      "type": "bargauge",
      "targets": [
        {
          "expr": "ccp_waterfall_applied_by_step",
          "legendFormat": "{{step_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Loss Recovery Rate",
      "type": "gauge",
      "targets": [
        {
          "expr": "1 - (ccp_waterfall_remaining_loss / ccp_waterfall_total_exposure)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Default Fund Utilization",
      "type": "timeseries",
      "targets": [
        {
          "expr": "ccp_default_fund_total",
          "legendFormat": "Total Fund"
        },
        {
          "expr": "ccp_default_fund_utilized",
          "legendFormat": "Utilized"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ccp", "default", "waterfall"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "CCP Default Waterfall",
  "uid": "ccp-default-waterfall"
}
